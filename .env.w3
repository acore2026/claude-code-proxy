# Default environment for Huawei W3 MiniMax mode.
# This file is safe to commit; OAuth credentials are stored in W3_TOKEN_FILE.

W3_OAUTH_ENABLED=true
W3_API_BASE_URL=https://codeagentcli.rnd.huawei.com/codeAgentPro
W3_MODEL=MiniMax-M2.7
W3_TOKEN_FILE=/data/.hw_minimax_oauth.json
W3_OPEN_BROWSER=false
W3_VERIFY_TLS=false
W3_REFRESH_SKEW_SECONDS=300
W3_AUTH_TIMEOUT_SECONDS=300

BIG_MODEL=MiniMax-M2.7
MIDDLE_MODEL=MiniMax-M2.7
SMALL_MODEL=MiniMax-M2.7

HOST=0.0.0.0
PORT=8082
LOG_LEVEL=INFO
MAX_TOKENS_LIMIT=24576
MIN_TOKENS_LIMIT=100
REQUEST_TIMEOUT=90
MAX_RETRIES=2
